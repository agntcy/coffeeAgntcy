# Directory Federation Nodes Configuration
# Add as many nodes as needed by incrementing the number

# Directory Federation Nodes Configuration
# Comma-separated list: name1:address1,name2:address2,...
FEDERATION_NODES=Node 1:sn-dir1.labs.outshift.com:8888,Node 2:sn-dir2.labs.outshift.com:8888

# Default node for operations (fallback)
DEFAULT_NODE_ADDRESS=sn-dir1.labs.outshift.com:8888

# Authentication Configuration
# Supported modes: x509 (SPIRE), insecure, token
AUTH_MODE=x509

# SPIRE/x509 authentication (when AUTH_MODE=x509)
SPIFFE_SOCKET_PATH=unix:///run/spire/sockets/agent.sock

# Token authentication (when AUTH_MODE=token)
# AUTH_TOKEN=your-bearer-token-here

# Insecure mode (when AUTH_MODE=insecure)
# No additional configuration needed

# Frontend API endpoint (leave empty for default: window.location.origin + '/api')
# FRONTEND_API_URL=http://localhost:5000/api
