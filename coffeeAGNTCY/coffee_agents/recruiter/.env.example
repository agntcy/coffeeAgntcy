PYTHONPATH=.

#============================
# Agent directory settings
#============================

# DIRECTORY_CLIENT_SERVER_ADDRESS="localhost:8888"
# DIRECTORY_CLIENT_TLS_SKIP_VERIFY="true"

# CACHE_ENABLED="true"
# CACHE_MODE="tool"


#============================
# LLM Provider Settings
#============================
# CoffeeAGNTCY uses litellm to manage LLM connections.
# Full list of supported providers:https://docs.litellm.ai/docs/providers
# Note: In CoffeeAGNTCY, the environment variable for specifying the model is always LLM_MODEL, regardless of the provider.
# Examples:

# OpenAI
# LLM_MODEL="openai/<model_of_choice>"
# OPENAI_API_KEY=<your_openai_api_key>

# Azure OpenAI
# LLM_MODEL="azure/<your_deployment_name>"
# AZURE_API_BASE=https://your-azure-resource.openai.azure.com/
# AZURE_API_KEY=<your_azure_api_key>
# AZURE_API_VERSION=<your_azure_api_version>

# GROQ
# LLM_MODEL="groq/<model_of_choice>"
# GROQ_API_KEY=<your_groq_api_key>

# Litellm Proxy
# LLM_MODEL="azure/<your_deployment_name>"
# LITELLM_PROXY_BASE_URL=<your_litellm_proxy_base_url>
# LITELLM_PROXY_API_KEY=<your_litellm_proxy_api_key>

# NVIDIA NIM
# LLM_MODEL="nvidia_nim/<model_of_choice>"
# NVIDIA_NIM_API_KEY=<your_nvidia_api_key>
# NVIDIA_NIM_API_BASE=<your_nvidia_nim_endpoint_url>

# Recommended temperature setting for OpenAI models
OPENAI_TEMPERATURE=0

# === Agntcy TBAC Settings ===
IDENTITY_SERVICE_API_KEY=<your_agntcy_identity_service_api_key>
IDENTITY_API_SERVER_URL="https://api.agent-identity.outshift.com"

#============================
# Local Development Settings
#============================
#(not needed when running Docker Compose)

# OTEL environment variables
# OTLP_HTTP_ENDPOINT="http://localhost:4318"

# === Transport Settings ===
# NATS (Default):
# DEFAULT_MESSAGE_TRANSPORT=NATS
# TRANSPORT_SERVER_ENDPOINT=nats://localhost:4222

# Alternative: SLIM transport (uncomment to use SLIM). The endpoint address must be in the form: http://host:port.
# For group conversation, SLIM transport is required.
# DEFAULT_MESSAGE_TRANSPORT=SLIM
# TRANSPORT_SERVER_ENDPOINT=http://localhost:46357

# Shared secret for SLIM identity handshake. Required by the `a2a-send` CLI
# (and the /agntcy-discover-connect:a2a-send command) when talking to any
# agent that advertises a slim/slimrpc interface in its agent card. Must
# match the secret the target agent was started with — for the coffee_agents
# lungo stack, that's the value in `coffee_agents/lungo/.env`.
SLIM_SHARED_SECRET="slim-shared-secret-REPLACE_WITH_RANDOM_32PLUS_CHARS"


# === Agntcy TBAC Settings (Local) ===
# For local development, set IDENTITY_AUTH_ENABLED to true to enable Agntcy Identity Auth (TBAC).
IDENTITY_AUTH_ENABLED="true"

# set the variable IDENTITY_SERVICE_API_KEY in different terminals for each service.




