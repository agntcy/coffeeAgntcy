# ---------- /check-identity ----------
# Required only by /agntcy-discover-connect:check-identity.
# Skip if you don't need to inspect identity-service badges.

# Base URL of the AGNTCY identity service.
# Hosted: https://api.agent-identity.outshift.com
# Local:  http://0.0.0.0:4000
IDENTITY_API_SERVER_URL="https://api.agent-identity.outshift.com"

# Sent as the `x-id-api-key` header on every identity-service call.
IDENTITY_SERVICE_API_KEY=<your_agntcy_identity_service_api_key>

# ---------- /a2a-send and recruited skills ----------
# Required only when the target A2A agent advertises a
# `slim`/`slimrpc` interface in its agent card. HTTP-only
# agents don't need this.
#
# Must match the secret the target agent was started with.
# For the coffee_agents/lungo stack, copy the value from
# coffee_agents/lungo/.env.
SLIM_SHARED_SECRET="slim-shared-secret-REPLACE_WITH_RANDOM_32PLUS_CHARS"

# ---------- /recruit ----------
# No environment variables required.