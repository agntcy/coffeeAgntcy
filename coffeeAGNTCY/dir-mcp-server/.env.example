# Directory MCP Server - Environment Configuration
# Copy this file to .env and uncomment/configure the options you need

# ============================================================================
# REQUIRED: Directory Server Address
# ============================================================================
# Default directory node to connect to
# This is the primary directory server address used for all operations
# unless overridden per tool call
DIRECTORY_SERVER_ADDRESS=localhost:8888
# DIRECTORY_SERVER_ADDRESS=dir1.example.com:8888

# ============================================================================
# OPTIONAL: SPIFFE Authentication (Production)
# ============================================================================
# Path to SPIFFE Workload API socket
# Required for both X.509 and JWT authentication modes
# The socket must be accessible from the container (mount as volume)
#SPIFFE_SOCKET_PATH=/run/spire/sockets/agent.sock

# Authentication mode: x509, jwt, or omit for insecure
# - x509: Uses X.509-SVID certificates for mutual TLS (recommended)
# - jwt: Uses JWT-SVID tokens in authorization headers
# - (empty): Insecure mode, no authentication (development only)
#AUTH_MODE=x509
#AUTH_MODE=jwt

# ============================================================================
# OPTIONAL: JWT-Specific Configuration
# ============================================================================
# JWT audience claim - required only when AUTH_MODE=jwt
# Must match the audience expected by the directory server
# Typically the SPIFFE ID of the directory server
#JWT_AUDIENCE=spiffe://example.org/directory-server
#JWT_AUDIENCE=spiffe://sn-dir1.labs.outshift.com/directory-server

# ============================================================================
# AUTHENTICATION MODE EXAMPLES
# ============================================================================

# Example 1: Development (No Authentication)
# DIRECTORY_SERVER_ADDRESS=localhost:8888
# (No SPIFFE variables needed)

# Example 2: Production with X.509 (Recommended)
# DIRECTORY_SERVER_ADDRESS=dir1.example.com:8888
# SPIFFE_SOCKET_PATH=/run/spire/sockets/agent.sock
# AUTH_MODE=x509

# Example 3: Production with JWT
# DIRECTORY_SERVER_ADDRESS=dir1.example.com:8888
# SPIFFE_SOCKET_PATH=/run/spire/sockets/agent.sock
# AUTH_MODE=jwt
# JWT_AUDIENCE=spiffe://example.org/directory-server

# ============================================================================
# NOTES
# ============================================================================
# 
# Authentication Scope:
# - Authentication is configured once at server startup
# - The same authentication applies to all directory nodes in the federation
# - Nodes share a common SPIFFE trust domain
# 
# Multi-Node Operations:
# - Set DIRECTORY_SERVER_ADDRESS as your default/primary node
# - Override per tool call using the 'node' parameter
# - Example: call_tool("search", {"node": "dir2.example.com:8888"})
# 
# X.509 vs JWT:
# - X.509: Uses streaming API, auto-rotates certificates, more efficient
# - JWT: Fetches fresh token per request, simpler but less efficient
# - Both are secure for production use
# 
# SPIFFE Socket:
# - Must be mounted into container: -v /run/spire/sockets:/run/spire/sockets:ro
# - Verify socket exists: ls -la /run/spire/sockets/agent.sock
# - Check SPIRE agent is running: ps aux | grep spire-agent
# 
# Security:
# - Never use insecure mode in production
# - Always mount SPIFFE socket as read-only (:ro)
# - Run container with minimal permissions
# - Use separate container from agent for isolation
